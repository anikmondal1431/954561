# ════════════════════════════════════════════════════════════════════════════
#  1. SERVER & APPLICATION
# ════════════════════════════════════════════════════════════════════════════

APP_NAME=Chakdaha Bazar
APP_VERSION=2.0.0
APP_ENV=production
PORT=3000
HOST=0.0.0.0
NODE_ENV=production
LOG_LEVEL=info

# ── URLs ──
FRONTEND_URL=https://chakdahabazar.in
ADMIN_URL=https://chakdahabazar.in/admin
API_BASE_URL=https://chakdahabazar.in/api
CDN_URL=https://res.cloudinary.com/chakdahabazar

# ── Hostinger-specific ──
HOSTINGER_DOMAIN=chakdahabazar.in
HOSTINGER_NODE_VERSION=18


# ════════════════════════════════════════════════════════════════════════════
#  2. DATABASE — MongoDB (Primary)
# ════════════════════════════════════════════════════════════════════════════

MONGO_URI=mongodb+srv://chakdaha_user:YOUR_MONGO_PASSWORD@cluster0.abcde.mongodb.net/chakdaha_bazar?retryWrites=true&w=majority
MONGO_DB_NAME=chakdaha_bazar
MONGO_POOL_SIZE=10
MONGO_TIMEOUT=30000

# ── MongoDB Atlas (Cloud) ──
MONGO_ATLAS_PUBLIC_KEY=your_atlas_public_key
MONGO_ATLAS_PRIVATE_KEY=your_atlas_private_key

# ── Backup Database — MySQL (Optional fallback) ──
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=chakdaha_db_user
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=chakdaha_bazar
MYSQL_SSL=false

# ── Fallback — JSON File Database (built-in, no setup needed) ──
JSON_DB_PATH=./data
USE_JSON_DB=true


# ════════════════════════════════════════════════════════════════════════════
#  3. AUTHENTICATION & SECURITY
# ════════════════════════════════════════════════════════════════════════════

# ── JWT ──
JWT_SECRET=cb_jwt_super_secret_key_change_this_in_production_min_64_chars_long
JWT_REFRESH_SECRET=cb_jwt_refresh_super_secret_key_change_this_also_min_64_chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d
JWT_ALGORITHM=HS256

# ── Admin Panel ──
ADMIN_PASSWORD=chakdaha@admin2025
ADMIN_EMAIL=anikmondal1431@gmail.com
ADMIN_SECRET_KEY=cb_admin_secret_key_minimum_32_characters_long

# ── Session ──
SESSION_SECRET=cb_session_secret_very_long_random_string_here_change_in_prod
SESSION_NAME=cb_session
SESSION_MAX_AGE=86400000
SESSION_SECURE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=strict

# ── Encryption ──
ENCRYPTION_KEY=cb_32_char_encryption_key_here__
ENCRYPTION_IV=cb_16char_iv_here

# ── CORS ──
CORS_ORIGIN=https://chakdahabazar.in,https://www.chakdahabazar.in
CORS_METHODS=GET,POST,PUT,DELETE,PATCH,OPTIONS
CORS_CREDENTIALS=true

# ── Rate Limiting ──
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_ADMIN_MAX=500
RATE_LIMIT_API_MAX=200
RATE_LIMIT_SKIP_SUCCESSFUL=false

# ── Helmet & CSP ──
HELMET_ENABLED=true
CSP_ENABLED=false


# ════════════════════════════════════════════════════════════════════════════
#  4. FIREBASE (Cloud Database — Optional)
# ════════════════════════════════════════════════════════════════════════════
# Leave empty to use built-in JSON database automatically

FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=
FIREBASE_MEASUREMENT_ID=
FIREBASE_DATABASE_URL=


# ════════════════════════════════════════════════════════════════════════════
#  5. PAYMENT GATEWAYS
# ════════════════════════════════════════════════════════════════════════════

# ── Razorpay (Primary — India) ──
RAZORPAY_KEY_ID=rzp_live_ENTER_YOUR_RAZORPAY_KEY_ID
RAZORPAY_KEY_SECRET=ENTER_YOUR_RAZORPAY_KEY_SECRET
RAZORPAY_WEBHOOK_SECRET=ENTER_YOUR_RAZORPAY_WEBHOOK_SECRET
RAZORPAY_CURRENCY=INR
RAZORPAY_MODE=live

# ── Stripe (International) ──
STRIPE_PUBLISHABLE_KEY=pk_live_ENTER_YOUR_STRIPE_PUBLISHABLE_KEY
STRIPE_SECRET_KEY=sk_live_ENTER_YOUR_STRIPE_SECRET_KEY
STRIPE_WEBHOOK_SECRET=whsec_ENTER_YOUR_STRIPE_WEBHOOK_SECRET
STRIPE_CURRENCY=inr
STRIPE_MODE=live

# ── PayPal ──
PAYPAL_CLIENT_ID=ENTER_YOUR_PAYPAL_CLIENT_ID_HERE
PAYPAL_CLIENT_SECRET=ENTER_YOUR_PAYPAL_CLIENT_SECRET_HERE
PAYPAL_MODE=live
PAYPAL_CURRENCY=USD
PAYPAL_WEBHOOK_ID=ENTER_YOUR_PAYPAL_WEBHOOK_ID

# ── UPI / PhonePe ──
PHONEPE_MERCHANT_ID=ENTER_YOUR_PHONEPE_MERCHANT_ID
PHONEPE_SALT_KEY=ENTER_YOUR_PHONEPE_SALT_KEY
PHONEPE_SALT_INDEX=1
PHONEPE_MODE=PRODUCTION

# ── Payment Global ──
FREE_DELIVERY_MIN=120
COD_ENABLED=true
ONLINE_PAYMENT_ENABLED=true
MAX_PAYMENT_RETRY=3


# ════════════════════════════════════════════════════════════════════════════
#  6. CLOUDINARY — IMAGE & MEDIA UPLOADS
# ════════════════════════════════════════════════════════════════════════════

CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=ENTER_CLOUDINARY_API_KEY
CLOUDINARY_API_SECRET=ENTER_CLOUDINARY_API_SECRET
CLOUDINARY_UPLOAD_PRESET=chakdaha_products
CLOUDINARY_FOLDER=chakdaha-bazar
CLOUDINARY_MAX_FILE_SIZE=10485760
CLOUDINARY_ALLOWED_FORMATS=jpg,jpeg,png,webp,gif


# ════════════════════════════════════════════════════════════════════════════
#  7. EMAIL — SMTP CONFIGURATION
# ════════════════════════════════════════════════════════════════════════════

# ── Primary SMTP (Gmail) ──
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=ENTER_YOUR_GMAIL_HERE
SMTP_PASSWORD=ENTER_YOUR_GMAIL_APP_PASSWORD
SMTP_FROM_NAME=Chakdaha Bazar
SMTP_FROM_EMAIL=no-reply@chakdahabazar.in

# ── Backup SMTP (Hostinger Mail) ──
SMTP_BACKUP_HOST=smtp.hostinger.com
SMTP_BACKUP_PORT=465
SMTP_BACKUP_SECURE=true
SMTP_BACKUP_USER=no-reply@chakdahabazar.in
SMTP_BACKUP_PASSWORD=ENTER_YOUR_HOSTINGER_MAIL_PASSWORD

# ── Email Templates ──
EMAIL_ORDER_CONFIRM=true
EMAIL_DELIVERY_UPDATE=true
EMAIL_WELCOME=true
EMAIL_RESET_PASSWORD=true

# ── SendGrid (Optional — for bulk emails) ──
SENDGRID_API_KEY=SG.ENTER_YOUR_SENDGRID_API_KEY
SENDGRID_TEMPLATE_ORDER=d-ENTER_TEMPLATE_ID
SENDGRID_TEMPLATE_WELCOME=d-ENTER_TEMPLATE_IDxxxxxxxxxxxxxxxxxxxxxxxx


