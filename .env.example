# ════════════════════════════════════════════════════════════════════════════
#  11. REDIS CACHE (Optional — for session & rate limiting)
# ════════════════════════════════════════════════════════════════════════════

REDIS_ENABLED=false
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=ENTER_REDIS_PASSWORD_HERE
REDIS_DB=0
REDIS_TTL=3600
REDIS_PREFIX=chakdaha:
REDIS_URL=redis://:ENTER_PASSWORD@127.0.0.1:6379/0

# ── Redis Cloud (Optional) ──
REDIS_CLOUD_URL=redis://default:ENTER_TOKEN@redis-xxxxx.cloud.redislabs.com:11000


# ════════════════════════════════════════════════════════════════════════════
#  12. CDN CONFIGURATION (Optional)
# ════════════════════════════════════════════════════════════════════════════

CDN_ENABLED=false
CDN_PROVIDER=cloudflare
CDN_BASE_URL=https://cdn.chakdahabazar.in
CDN_ZONE_ID=your_cloudflare_zone_id
CDN_AUTH_EMAIL=anikmondal1431@gmail.com
CDN_AUTH_KEY=your_cloudflare_global_api_key
CDN_CACHE_TTL=86400


# ════════════════════════════════════════════════════════════════════════════
#  13. PRODUCT & INVENTORY MANAGEMENT
# ════════════════════════════════════════════════════════════════════════════

LOW_STOCK_ALERT_THRESHOLD=5
OUT_OF_STOCK_HIDE=false
MAX_UPLOAD_SIZE_MB=10
PRODUCT_IMAGE_QUALITY=85
ENABLE_PRODUCT_REVIEWS=true
REVIEW_MODERATION=false
MAX_REVIEWS_PER_PRODUCT=100
ENABLE_WISHLIST=true
ENABLE_COMPARE=false


# ════════════════════════════════════════════════════════════════════════════
#  14. ORDER & DELIVERY MANAGEMENT
# ════════════════════════════════════════════════════════════════════════════

ORDER_ID_PREFIX=CB
ORDER_EXPIRY_HOURS=24
AUTO_CONFIRM_COD=true
AUTO_CONFIRM_ONLINE=true
DELIVERY_SLOT_ENABLED=true
NEXT_DAY_DELIVERY=true
SAME_DAY_DELIVERY=false
DELIVERY_CHARGE=30
FREE_DELIVERY_ABOVE=120
MAX_DELIVERY_ATTEMPTS=3
ORDER_CANCELLATION_WINDOW_HOURS=2


# ════════════════════════════════════════════════════════════════════════════
#  15. ANALYTICS & REPORTING
# ════════════════════════════════════════════════════════════════════════════

ANALYTICS_ENABLED=true
REVENUE_REPORT_EMAIL=anikmondal1431@gmail.com
DAILY_REPORT_TIME=23:59
WEEKLY_REPORT_DAY=sunday
EXPORT_FORMAT=xlsx,csv,pdf
DATA_RETENTION_DAYS=365

# ── Mixpanel (Optional) ──
MIXPANEL_TOKEN=your_mixpanel_project_token

# ── Hotjar (Optional) ──
HOTJAR_ID=your_hotjar_site_id


# ════════════════════════════════════════════════════════════════════════════
#  16. LOGGING CONFIGURATION
# ════════════════════════════════════════════════════════════════════════════

LOG_ENABLED=true
LOG_LEVEL=info
LOG_FORMAT=combined
LOG_DIR=./logs
LOG_MAX_SIZE=20m
LOG_MAX_FILES=14d
LOG_CONSOLE=true
LOG_FILE=true
LOG_ERROR_FILE=./logs/error.log
LOG_COMBINED_FILE=./logs/combined.log

# ── Sentry Error Tracking (Optional) ──
SENTRY_DSN=https://your_key@sentry.io/your_project_id
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1


# ════════════════════════════════════════════════════════════════════════════
#  17. SECURITY & COMPLIANCE
# ════════════════════════════════════════════════════════════════════════════

BCRYPT_ROUNDS=12
OTP_LENGTH=6
OTP_EXPIRY_MINUTES=10
OTP_MAX_ATTEMPTS=3
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=15
IP_WHITELIST_ADMIN=
ENABLE_2FA=false
HTTPS_REDIRECT=true
TRUST_PROXY=1


# ════════════════════════════════════════════════════════════════════════════
#  18. HOSTINGER DEPLOYMENT SPECIFIC
# ════════════════════════════════════════════════════════════════════════════

HOSTINGER_SITE_NAME=chakdahabazar
HOSTINGER_PHP_VERSION=8.1
HOSTINGER_NODE_ENV=production
HOSTINGER_MEMORY_LIMIT=512
HOSTINGER_TIMEOUT=30
KEEP_ALIVE=true
COMPRESSION_ENABLED=true
STATIC_CACHE_MAX_AGE=86400
